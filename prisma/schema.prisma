generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// -----------------------------------------------------------------------------
// IDENTITY & MULTI-TENANCY
// -----------------------------------------------------------------------------

model Organization {
  id          String   @id @default(uuid())
  name        String
  domain      String?  @unique
  annualTurnover Float @default(0.0)
  legalJurisdiction String @default("EU")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]
  audits      Audit[]
  incidents   Incident[]
  nodes       NetworkNode[]
  policies      Policy[]
  vaultKeys     VaultKey[]
  notifications Notification[]
  entities      LegalEntity[]
}

model User {
  id             String       @id @default(uuid())
  clerkId        String       @unique
  email          String       @unique
  firstName      String?
  lastName       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           SystemRole   @default(AUDITOR)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  auditEvents    AuditEvent[]
  assignedTasks  CAPATask[]   @relation("TaskAssignee")
  userAccount    UserAccount?
}

enum SystemRole {
  ADMIN
  AUDITOR
  COMPLIANCE_OFFICER
  IT_MANAGER
  VIEWER
}

// -----------------------------------------------------------------------------
// CORE AUDIT & FORENSICS (Immutable Ledger Pattern)
// -----------------------------------------------------------------------------

model Audit {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  templateId     String
  template       AuditTemplate @relation(fields: [templateId], references: [id])
  status         AuditStatus   @default(DRAFT)
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  
  events         AuditEvent[]
}

enum AuditStatus {
  DRAFT
  IN_PROGRESS
  IN_REVIEW
  SUBMITTED
  CLOSED
}

model AuditTemplate {
  id          String   @id @default(uuid())
  title       String
  description String?
  version     Int      @default(1)
  content     Json     // Dynamic schema for audit structure
  createdAt   DateTime @default(now())
  
  audits      Audit[]
}

model AuditEvent {
  id          String   @id @default(uuid())
  auditId     String
  audit       Audit    @relation(fields: [auditId], references: [id])
  type        String   // e.g., 'DATA_ENTRY', 'SIGNATURE', 'EVIDENCE_UPLOAD'
  timestamp   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  payload     Json
  sha256Hash  String   @unique
  previousHash String? // Blockchain-style chained hashes for forensics
  signature    String? // Cryptographic signature of the hash
  signer2Id    String? // For Two-Man Rule
  signature2   String? // Second signature for critical actions

  @@index([auditId, timestamp])
}

// -----------------------------------------------------------------------------
// INFRASTRUCTURE & TOPOLOGY
// -----------------------------------------------------------------------------

model NetworkNode {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  region         String
  type           NodeType
  status         NodeStatus   @default(HEALTHY)
  ipAddress      String?
  lastSync       DateTime?
  tags           Json?        // Classification tags (e.g., PI, Highly Confidential)
  createdAt      DateTime     @default(now())

  
  incidents      Incident[]
}

enum NodeType {
  VIRTUAL_MACHINE
  DATABASE
  KUBERNETES_CLUSTER
  API_GATEWAY
  FIREWALL
}

enum NodeStatus {
  HEALTHY
  DEGRADED
  DOWN
  MAINTENANCE
}

// -----------------------------------------------------------------------------
// COMPLIANCE & RISK
// -----------------------------------------------------------------------------

model Policy {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  title          String
  framework      String       // e.g., 'ISO-27001', 'SOC2', 'GDPR'
  content        String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  controls       Control[]
}

model Control {
  id          String   @id @default(uuid())
  policyId    String
  policy      Policy   @relation(fields: [policyId], references: [id])
  name        String
  description String
  frequency   String   // e.g., 'ANNUAL', 'CONTINUOUS'
  status      String   // e.g., 'COMPLIANT', 'NON_COMPLIANT', 'NOT_TESTED'
  
  entityId    String?
  entity      LegalEntity? @relation(fields: [entityId], references: [id])
  
  impact      ComplianceGapImpact?
}

model ComplianceGapImpact {
  id               String   @id @default(uuid())
  controlId        String   @unique
  control          Control  @relation(fields: [controlId], references: [id])
  potentialFine    Float    @default(0.0)
  interruptionCost Float    @default(0.0) 
  remediationCost  Float    @default(0.0)
  probability      Float    @default(0.05)
  currency         String   @default("EUR")
  updatedAt        DateTime @updatedAt
}

model RiskAssessment {
  id             String   @id @default(uuid())
  jurisdiction   String
  riskScore      Float
  category       String
  details        String
  assessedAt     DateTime @default(now())
}

// -----------------------------------------------------------------------------
// INCIDENTS & REMEDIATION (CAPA)
// -----------------------------------------------------------------------------

model Incident {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  nodeId         String?
  node           NetworkNode? @relation(fields: [nodeId], references: [id])
  title          String
  severity       Severity
  status         IncidentStatus @default(OPEN)
  detectedAt     DateTime     @default(now())
  resolvedAt     DateTime?
  
  tasks          CAPATask[]
}

model CAPATask {
  id          String       @id @default(uuid())
  incidentId  String
  incident    Incident     @relation(fields: [incidentId], references: [id])
  title       String
  description String
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  MITIGATED
  RESOLVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

// -----------------------------------------------------------------------------
// PHASE 7: AGENTIC ENGINE & BILLING
// -----------------------------------------------------------------------------

model UserAccount {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  balance        Float    @default(10.0)
  totalSpent     Float    @default(0.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  usageLogs      AIUsageLog[]
}

model AIUsageLog {
  id            String      @id @default(uuid())
  userAccountId String
  userAccount   UserAccount @relation(fields: [userAccountId], references: [id])
  action        String     // 'SIMPLE' | 'DSL' | 'AGENTIC'
  cost          Float
  auditId       String?
  loopCount     Int        @default(1)
  promptVersion String     @default("v1.0.0")
  timestamp     DateTime   @default(now())
}

model LogicRule {
  id          String   @id @default(uuid())
  auditId     String
  questionId  String
  fact        String
  operator    String   // 'lt' | 'gt' | 'eq' | 'contains'
  value       String   // JSON serialized
  severity    String   // 'CRITICAL' | 'MAJOR' | 'MINOR'
  compliant   Boolean
  reason      String
  createdAt   DateTime @default(now())
}

model VaultKey {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  type           String       // 'AES-256-GCM', 'RSA-2048', 'ED25519'
  status         String       @default("ACTIVE") // 'ACTIVE', 'ROTATING', 'DEPRECATED'
  encryptedValue String       // In a real app, this would be highly protected
  entropy        Float        @default(0.98)
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model LegalEntity {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  parentId       String?
  parent         LegalEntity? @relation("Hierarchy", fields: [parentId], references: [id])
  children       LegalEntity[] @relation("Hierarchy")
  jurisdiction   String
  countryCode    String       @default("US")
  localTurnover  Float        @default(0.0)
  liabilityType  String       @default("LIMITED") // FULL or LIMITED
  ownerPercent   Float        @default(100.0)
  status         String       @default("VERIFIED")
  taxId          String?
  createdAt      DateTime     @default(now())
  
  controls       Control[]
}

model Notification {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  title          String
  message        String
  type           String       // 'INFO', 'WARNING', 'CRITICAL', 'SUCCESS'
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model ConflictOfInterest {
  id          String   @id @default(uuid())
  auditorId   String
  auditorName String
  target      String
  severity    String   // 'HIGH' | 'MEDIUM' | 'LOW'
  detail      String
  date        DateTime @default(now())
  status      String   @default("OPEN")
}
